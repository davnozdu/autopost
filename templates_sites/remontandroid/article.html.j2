{# Шаблон статьи remontandroid (Jinja2). Загружается в админку сайта.
   Генератор передаёт: lang, slug, title, meta_description, keywords, tag,
   image_url, body_html, date_iso, date_human.
   Домен/бэклинк/обвязку шаблон строит сам (он привязан к конкретному сайту). #}
{%- set domain = "https://remontandroid.cz" -%}
{%- set url = "/" ~ lang ~ "/blog/" ~ slug ~ "/" -%}
{%- set canonical = domain ~ url -%}
<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <title>{{ title }} | remontandroid</title>
  <meta name="description" content="{{ meta_description }}" />
  <meta name="keywords" content="{{ keywords }}" />
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />
  <meta name="author" content="Big Tweak s.r.o." />

  <link rel="canonical" href="{{ canonical }}" />
  {% for alt in alternates %}<link rel="alternate" hreflang="{{ alt }}" href="{{ domain }}/{{ alt }}/blog/{{ slug }}/" />
  {% endfor %}{% if alternates %}<link rel="alternate" hreflang="x-default" href="{{ domain }}/{{ alternates[0] }}/blog/{{ slug }}/" />{% endif %}
  <link rel="icon" type="image/png" href="/assets/logo.png" />

  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ meta_description }}" />
  <meta property="og:url" content="{{ canonical }}" />
  {% if image_url %}<meta property="og:image" content="{{ image_url }}" />{% endif %}
  <meta property="article:published_time" content="{{ date_iso }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  {% if image_url %}<meta name="twitter:image" content="{{ image_url }}" />{% endif %}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": {{ title | tojson }},
    {% if image_url %}"image": [{{ image_url | tojson }}],{% endif %}
    "datePublished": "{{ date_iso }}",
    "dateModified": "{{ date_iso }}",
    "author": { "@type": "Organization", "name": "Big Tweak s.r.o." },
    "publisher": {
      "@type": "Organization",
      "name": "remontandroid — Big Tweak s.r.o.",
      "logo": { "@type": "ImageObject", "url": "{{ domain }}/assets/logo.png" }
    },
    "mainEntityOfPage": "{{ canonical }}"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div id="site-header">
    <a class="brand" href="/{{ lang }}/" style="display:inline-flex;align-items:center;gap:10px;padding:14px 20px"><img src="/assets/logo.png" alt="remontandroid" width="30" height="30"> <strong style="font-family:'Space Grotesk',sans-serif">remontandroid</strong></a>
  </div>

  <div class="container">
    <article class="article">
      <h1 style="font-family:var(--f-display);font-weight:600;font-size:32px;line-height:1.15;letter-spacing:-0.02em;margin:24px 0 4px">{{ title }}</h1>
      <div class="article__meta"><span>{{ date_human }}</span>{% if tag %}<span class="news__tag">{{ tag }}</span>{% endif %}</div>
      {% if image_url %}<img class="article__cover" src="{{ image_url }}" alt="{{ title }}" />{% endif %}

      <div class="article__body">{{ body_html | safe }}</div>

      {# Бэклинк на сайт (в теле → уходит при репосте). Текст по языку. #}
      <div class="article__backlink">
        {% if lang == 'ru' %}Материал подготовлен сервисным центром <a href="{{ domain }}/ru/">remontandroid.cz — ремонт Android в Праге</a>. Звоните: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
        {% elif lang == 'uk' %}Матеріал підготував сервісний центр <a href="{{ domain }}/uk/">remontandroid.cz — ремонт Android у Празі</a>. Телефонуйте: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
        {% elif lang == 'en' %}Prepared by <a href="{{ domain }}/en/">remontandroid.cz — Android repair in Prague</a>. Call: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
        {% else %}Připravil servis <a href="{{ domain }}/cs/">remontandroid.cz — opravy Androidu v Praze</a>. Volejte: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
        {% endif %}
      </div>
    </article>
  </div>

  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" crossorigin="anonymous"></script>
  <script src="/i18n.js"></script>
  <script type="text/babel" src="/components.jsx"></script>
  <script type="text/babel" src="/blog-header.jsx"></script>
</body>
</html>
