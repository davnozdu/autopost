{# Шаблон статьи gamefix.cz (Jinja2). Загружается в админку сайта.
   Генератор передаёт: lang, slug, title, meta_description, keywords, tag,
   image_url, body_html, date_iso, date_human, annotation, alternates.
   Сайт статический (без React) — страница самодостаточна и тянет /assets/blog.css.
   Листинг/пагинацию/RSS/sitemap строит PHP на сервере. #}
{%- set domain = "https://gamefix.cz" -%}
{%- set url = "/" ~ lang ~ "/blog/" ~ slug ~ "/" -%}
{%- set canonical = domain ~ url -%}
{%- set share = domain ~ "/assets/share.png" -%}
{%- set og_image = image_url or share -%}
{%- set nav = {
  "cs": {"services": "Služby", "catalog": "Katalog", "prices": "Ceny", "news": "Novinky", "about": "O nás", "contact": "Kontakt", "book": "Rezervace", "back": "Všechny novinky", "skip": "Přejít na obsah"},
  "en": {"services": "Services", "catalog": "Catalog", "prices": "Prices", "news": "News", "about": "About", "contact": "Contact", "book": "Book now", "back": "All news", "skip": "Skip to content"},
  "ru": {"services": "Услуги", "catalog": "Каталог", "prices": "Цены", "news": "Новости", "about": "О нас", "contact": "Контакты", "book": "Запись", "back": "Все новости", "skip": "Перейти к содержимому"}
} -%}
{%- set n = nav.get(lang, nav["cs"]) -%}
<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{{ title }} | Gamefix</title>
  <meta name="description" content="{{ meta_description }}" />
  <meta name="keywords" content="{{ keywords }}" />
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />
  <meta name="author" content="Big Tweak s.r.o." />

  <link rel="canonical" href="{{ canonical }}" />
  {% for alt in alternates %}<link rel="alternate" hreflang="{{ alt }}" href="{{ domain }}/{{ alt }}/blog/{{ slug }}/" />
  {% endfor %}{% if alternates %}<link rel="alternate" hreflang="x-default" href="{{ domain }}/{{ 'en' if 'en' in alternates else alternates[0] }}/blog/{{ slug }}/" />{% endif %}
  <link rel="icon" href="/assets/logo.png" />

  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="Gamefix" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ meta_description }}" />
  <meta property="og:url" content="{{ canonical }}" />
  <meta property="og:image" content="{{ og_image }}" />
  <meta property="article:published_time" content="{{ date_iso }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ meta_description }}" />
  <meta name="twitter:image" content="{{ og_image }}" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": {{ title | tojson }},
    {% if image_url %}"image": [{{ image_url | tojson }}],{% endif %}
    "datePublished": "{{ date_iso }}",
    "dateModified": "{{ date_iso }}",
    "author": { "@type": "Organization", "name": "Big Tweak s.r.o." },
    "publisher": {
      "@type": "Organization",
      "name": "Gamefix — Big Tweak s.r.o.",
      "logo": { "@type": "ImageObject", "url": "{{ domain }}/assets/logo.png" }
    },
    "mainEntityOfPage": "{{ canonical }}"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/blog.css" />
</head>
<body>
  <a class="skip-link" href="#main">{{ n.skip }}</a>
  <header class="hdr">
    <div class="hdr-inner">
      <a class="brand" href="/{{ lang }}/"><span class="brand-mark"><img src="/assets/logo.png" alt="Gamefix"></span><span class="brand-name">gamefix<span class="brand-dot">.</span>cz</span></a>
      <nav id="nav-menu" class="nav">
        <a href="/{{ lang }}/index.html#services">{{ n.services }}</a>
        <a href="/{{ lang }}/catalog.html">{{ n.catalog }}</a>
        <a href="/{{ lang }}/prices.html">{{ n.prices }}</a>
        <a href="/{{ lang }}/blog/" class="is-active">{{ n.news }}</a>
        <a href="/{{ lang }}/index.html#about">{{ n.about }}</a>
        <a href="/{{ lang }}/index.html#contact">{{ n.contact }}</a>
      </nav>
      <div class="hdr-actions">
        <div class="lang-switch lang-switch--compact">{% for l in ["cs", "en", "ru"] %}<a href="/{{ l }}/blog/{{ slug }}/" class="lang-btn{% if l == lang %} lang-btn--active{% endif %}">{{ l | upper }}</a>{% endfor %}</div>
        <a class="hdr-phone" href="tel:+420608210867"><span>+420 608 210 867</span></a>
        <a href="https://cal.com/bigtweak/bookcz" class="btn btn--primary btn--sm">{{ n.book }}</a>
        <button id="menu-toggle" class="menu-toggle" aria-label="Menu"><span></span><span></span><span></span></button>
      </div>
    </div>
  </header>

  <main id="main" class="article-wrap">
    <div class="container">
      <article class="article">
        <a class="article__back" href="/{{ lang }}/blog/">← {{ n.back }}</a>
        <h1 class="article__title">{{ title }}</h1>
        <div class="article__meta"><span>{{ date_human }}</span>{% if tag %}<span class="news-card__tag">{{ tag }}</span>{% endif %}</div>
        {% if image_url %}<img class="article__cover" src="{{ image_url }}" alt="{{ title }}" />{% endif %}

        <div class="article__body">{{ body_html | safe }}</div>

        {# Бэклинк на сайт (в теле → уходит при репосте). Текст по языку. #}
        <div class="article__backlink">
          {% if lang == 'ru' %}Материал подготовлен сервисом <a href="{{ domain }}/ru/">gamefix.cz — ремонт игровых консолей в Праге</a> (Steam Deck, ROG Ally). Звоните: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
          {% elif lang == 'en' %}Prepared by <a href="{{ domain }}/en/">gamefix.cz — gaming handheld repair in Prague</a> (Steam Deck, ROG Ally). Call: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
          {% else %}Připravil servis <a href="{{ domain }}/cs/">gamefix.cz — opravy herních konzolí v Praze</a> (Steam Deck, ROG Ally). Volejte: <a href="tel:+420608210867">+420&nbsp;608&nbsp;210&nbsp;867</a>.
          {% endif %}
        </div>
      </article>
    </div>
  </main>

  <footer class="ftr">
    <div class="ftr-inner">
      <div class="ftr-brand">
        <div class="brand"><span class="brand-mark"><img src="/assets/logo.png" alt="Gamefix"></span><span class="brand-name">gamefix<span class="brand-dot">.</span>cz</span></div>
        <p class="ftr-tag">Praha 1, Senovážné náměstí 978/23, Office 101</p>
      </div>
      <div class="ftr-cols">
        <div class="ftr-col"><div class="ftr-ttl">Telefon</div><a href="tel:+420608210867">+420 608 210 867</a></div>
        <div class="ftr-col"><div class="ftr-ttl">E-mail</div><a href="mailto:info@gamefix.cz">info@gamefix.cz</a></div>
        <div class="ftr-col"><div class="ftr-ttl">{{ n.news }}</div><a href="/{{ lang }}/blog/">{{ n.back }}</a></div>
        <div class="ftr-col"><div class="ftr-ttl">Language</div><div class="lang-switch">{% for l in ["cs", "en", "ru"] %}<a href="/{{ l }}/blog/{{ slug }}/" class="lang-btn{% if l == lang %} lang-btn--active{% endif %}">{{ l | upper }}</a>{% endfor %}</div></div>
      </div>
      <div class="ftr-bot">
        <span>© {{ date_iso[:4] }} Gamefix.{% if lang == 'ru' %} Все права защищены.{% elif lang == 'en' %} All rights reserved.{% else %} Všechna práva vyhrazena.{% endif %}</span>
        <span class="ftr-made">Praha</span>
      </div>
    </div>
  </footer>
  <script>document.addEventListener('DOMContentLoaded',function(){var t=document.getElementById('menu-toggle'),m=document.getElementById('nav-menu');if(t&&m)t.addEventListener('click',function(){m.classList.toggle('nav--open');});});</script>
</body>
</html>
