# ── LLM ───────────────────────────────────────────────────────────────
# Провайдер: deepseek | hermes | openai | claude | local
LLM_PROVIDER=deepseek

# base_url переопределяет дефолт пресета.
#   deepseek → можно не указывать (https://api.deepseek.com/v1)
#   hermes   → ОБЯЗАТЕЛЬНО укажите адрес вашего эндпоинта, напр.:
# LLM_BASE_URL=http://localhost:8642/v1
LLM_BASE_URL=

LLM_KEY=your-api-key
# Пусто → берётся модель по умолчанию для провайдера
#   deepseek → deepseek-v4-flash (есть ещё deepseek-v4-pro);  hermes → hermes
# Модель DeepSeek также переключается в админке (Настройки).
LLM_MODEL=

# ── Сессии/данные ─────────────────────────────────────────────────────
# Подпись cookie. Сделайте длинным и случайным. При смене все входы сбросятся.
# Пароль администратора НЕ здесь — он задаётся при первом входе в браузере.
SECRET_KEY=change-me-to-a-long-random-string

# Каталог данных (БД + собранные новости). Внутри контейнера — /app/data.
DATA_DIR=data
